<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /medical/

    # Skip if it's a real file
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Skip if it's a real directory
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite everything else to public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

