<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /medical/

    # Skip if already rewritten (prevent infinite loop)
    RewriteCond %{ENV:REWRITE_DONE} ^$
    # Don't rewrite actual files
    RewriteCond %{REQUEST_FILENAME} !-f
    # Don't rewrite actual directories
    RewriteCond %{REQUEST_FILENAME} !-d
    # Don't rewrite if already pointing to public
    RewriteCond %{REQUEST_FILENAME} !^.*/public/
    # Rewrite to public folder
    RewriteRule ^(.*)$ public/$1 [L,E=REWRITE_DONE:1]
</IfModule>

