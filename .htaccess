<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /medical/

    # Rewrite to public folder if not a real file or folder
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Prevent rewriting if already in public folder
    RewriteCond %{REQUEST_FILENAME} !^.*/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

