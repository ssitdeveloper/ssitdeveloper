<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /medical/

    # Don't rewrite if request is for actual file
    RewriteCond %{REQUEST_FILENAME} !-f
    # Don't rewrite if request is for actual directory
    RewriteCond %{REQUEST_FILENAME} !-d
    # Don't rewrite if already in public folder
    RewriteCond %{REQUEST_URI} !^/medical/public/
    # Internally rewrite to public folder (no redirect, so URL stays clean)
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

