<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /neet/

    # If the request is not for a file or directory in the root
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Don't rewrite requests already in the public directory
    RewriteCond %{REQUEST_URI} !^/neet/public/

    # Rewrite to public folder (internal rewrite, not a redirect)
    RewriteRule ^(.*)$ public/$1 [QSA,L]
</IfModule>

